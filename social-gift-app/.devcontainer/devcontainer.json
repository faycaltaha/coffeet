{
  "name": "Coffeet Gift App",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install && bash .devcontainer/setup-env.sh",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "App Next.js",
      "onAutoForward": "openBrowser"
    }
  },
  "secrets": {
    "OPENROUTER_API_KEY": {
      "description": "Clé API OpenRouter pour les recommandations cadeaux",
      "documentationUrl": "https://openrouter.ai/keys"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
