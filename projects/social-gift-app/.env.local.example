# Copy this file to .env.local and fill in your values

# OpenRouter — required for gift analysis (uses perplexity/sonar-pro with built-in web search)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Amazon Associates tag — sign up free at amazon.fr/associates
# Format: yourname-21  (the -21 suffix is standard for amazon.fr)
# Leave empty to link to Amazon without affiliate tracking
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=
