# ── Database ───────────────────────────────────────────────
POSTGRES_DB=carscan
POSTGRES_USER=carscan
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Set automatically by docker-compose — don't change:
# DATABASE_URL=postgresql+asyncpg://carscan:CHANGE_ME@db:5432/carscan

# ── Auth ───────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_hex_chars

# ── Stripe ─────────────────────────────────────────────────
# 1. Create account at stripe.com
# 2. Create a Product "CarScan IDF" + recurring Price €5/month
# 3. Copy the keys below from stripe.com/dashboard/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# 4. Add webhook endpoint in Stripe Dashboard:
#    URL: https://yourdomain.com/stripe/webhook
#    Events to listen:
#      - checkout.session.completed
#      - customer.subscription.updated
#      - customer.subscription.deleted

# ── App ────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
